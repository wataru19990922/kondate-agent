# backend/.env.example
# 実際の値を入れたものを backend/.env として保存する (git にコミットしない)

# --- GCP / Vertex AI ---
# 認証はキーレス: gcloud auth application-default login で取得した
# 個人 Gmail の ADC を直接利用する (infra/README.md 参照)。
# 長寿命の SA キーファイルは作らない方針。
GOOGLE_CLOUD_PROJECT=kondate-agent-2026
GOOGLE_CLOUD_LOCATION=asia-northeast1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GEMINI_MODEL=gemini-2.5-flash

# 必要なら ADC ファイルを既定パス以外に置いて GOOGLE_APPLICATION_CREDENTIALS で指す
# (会社業務のグローバル ADC を温存したい場合):
# GOOGLE_APPLICATION_CREDENTIALS=/Users/<you>/.config/gcloud/kondate-adc.json

# --- Elastic Cloud ---
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=
ELASTIC_RECIPE_INDEX=recipes

# --- 楽天レシピ API (バッチ用) ---
# 2025 年以降の新仕様: APP_ID は UUID 形式 / ACCESS_KEY が別途必須
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=

# --- アプリ ---
ENV=local
