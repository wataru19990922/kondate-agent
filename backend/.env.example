# backend/.env.example
# 実際の値を入れたものを backend/.env として保存する (git にコミットしない)

# --- GCP / Vertex AI ---
GOOGLE_CLOUD_PROJECT=kondate-agent
GOOGLE_CLOUD_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-2.5-flash

# --- Elastic Cloud ---
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=
ELASTIC_RECIPE_INDEX=recipes

# --- 楽天レシピ API (バッチ用) ---
# 2025 年以降の新仕様: APP_ID は UUID 形式 / ACCESS_KEY が別途必須
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=

# --- アプリ ---
ENV=local
